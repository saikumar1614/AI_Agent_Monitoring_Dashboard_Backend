# Application Settings
APP_NAME=AI Agent Monitoring Dashboard Backend
DEBUG=False
RELOAD=True

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_monitoring
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_monitoring

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Telemetry
LOG_LEVEL=INFO
LOG_JSON=True
ENABLE_TRACING=True
ENABLE_METRICS=True
ENABLE_LOGGING=True
TELEMETRY_EXPORTER=otlp
OTEL_SERVICE_NAME=ai-agent-monitoring-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
METRICS_PATH=/metrics
